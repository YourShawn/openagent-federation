[Unit]
Description=OpenAgent Federation API
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/oaf
EnvironmentFile=/opt/oaf/.env
ExecStart=/opt/oaf/.venv/bin/uvicorn server.main:app --host 0.0.0.0 --port 8787
Restart=always
RestartSec=3
User=root

[Install]
WantedBy=multi-user.target
